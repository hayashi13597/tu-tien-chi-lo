# Production secrets for docker-compose.prod.yml. Copy to `.env` on the VPS and
# fill with real random values. NEVER commit the real .env.
#
# Generate each with: openssl rand -hex 32   (DB_PASSWORD: openssl rand -hex 16)
# JWT_SECRET and JWT_REFRESH_SECRET MUST differ — the backend refuses to boot if
# they are equal, empty, or still the dev defaults (dev-secret-change-me).
DB_PASSWORD=change-me
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-different
