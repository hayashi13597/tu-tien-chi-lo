datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  // "native" covers local (host) dev/test; "linux-musl-openssl-3.0.x" is needed
  // for the `node:20-alpine` Docker image, whose current Alpine base (3.2x)
  // ships OpenSSL 3 only. Without this, Prisma's generic "linux-musl" engine
  // target (built against OpenSSL 1.1) fails to load inside the container with
  // "Error loading shared library libssl.so.1.1: No such file or directory".
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  character    Character?
}

model Character {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])

  realmMajor        Int       @default(0)
  realmSub          Int       @default(0)
  linhKhi           Float     @default(0)
  lastUpdateAt      DateTime  @default(now())

  breakthroughFails Int       @default(0)
  punishedUntil     DateTime?

  createdAt         DateTime  @default(now())
}
